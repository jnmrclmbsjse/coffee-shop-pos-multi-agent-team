{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "background": { "$type": "color", "$value": "oklch(98% 0.005 250)" },
    "surface": { "$type": "color", "$value": "oklch(100% 0 0)" },
    "foreground": { "$type": "color", "$value": "oklch(22% 0.02 240)" },
    "muted": { "$type": "color", "$value": "oklch(50% 0.018 240)" },
    "border": { "$type": "color", "$value": "oklch(90% 0.008 240)" },
    "accent": { "$type": "color", "$value": "oklch(58% 0.16 145)" },
    "accentHover": { "$type": "color", "$value": "oklch(52% 0.16 145)" },
    "accentPressed": { "$type": "color", "$value": "oklch(46% 0.14 145)" },
    "danger": { "$type": "color", "$value": "oklch(48% 0.18 28)" },
    "dangerSurface": { "$type": "color", "$value": "oklch(97% 0.018 28)" },
    "focus": { "$type": "color", "$value": "oklch(43% 0.14 145)" },
    "inkSoft": { "$type": "color", "$value": "oklch(36% 0.018 240)" },
    "surfaceSubtle": { "$type": "color", "$value": "oklch(96.5% 0.007 240)" },
    "borderStrong": { "$type": "color", "$value": "oklch(76% 0.012 240)" }
  },
  "font": {
    "display": { "$type": "fontFamily", "$value": ["-apple-system", "BlinkMacSystemFont", "Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "body": { "$type": "fontFamily", "$value": ["-apple-system", "BlinkMacSystemFont", "Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "IBM Plex Mono", "ui-monospace", "Menlo", "monospace"] }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "20px" },
    "6": { "$type": "dimension", "$value": "24px" },
    "8": { "$type": "dimension", "$value": "32px" },
    "10": { "$type": "dimension", "$value": "40px" },
    "12": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "small": { "$type": "dimension", "$value": "6px" },
    "medium": { "$type": "dimension", "$value": "10px" }
  },
  "control": {
    "minimumTouchTarget": { "$type": "dimension", "$value": "44px" },
    "fieldHeight": { "$type": "dimension", "$value": "48px" }
  },
  "shadow": {
    "control": {
      "$type": "shadow",
      "$value": [
        { "color": "oklch(22% 0.02 240 / 0.12)", "offsetX": "0px", "offsetY": "1px", "blur": "1px", "spread": "0px" },
        { "color": "oklch(22% 0.02 240 / 0.08)", "offsetX": "0px", "offsetY": "2px", "blur": "5px", "spread": "0px" }
      ]
    }
  }
}

